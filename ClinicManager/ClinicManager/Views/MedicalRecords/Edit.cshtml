@using System.ComponentModel.DataAnnotations
@using System.Reflection
@model MedicalRecordFormDto
@{
    ViewData["Title"] = "Edycja kartoteki";

    var bloodTypes = Enum.GetValues<BloodType>().Select(bt =>
    {
        var member = typeof(BloodType).GetMember(bt.ToString()).FirstOrDefault();
        var label = member?.GetCustomAttribute<DisplayAttribute>()?.Name ?? bt.ToString();
        return new SelectListItem
        {
            Value = ((int)bt).ToString(),
            Text = label,
            Selected = bt == Model.BloodType
        };
    }).ToList();
}

<h2>Edycja kartoteki</h2>

<form asp-action="Edit" asp-route-patientId="@Model.PatientId" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PatientId" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

    <div class="col-md-4">
        <label asp-for="BloodType" class="form-label"></label>
        <select asp-for="BloodType" asp-items="bloodTypes" class="form-select"></select>
        <span asp-validation-for="BloodType" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Allergies" class="form-label"></label>
        <textarea asp-for="Allergies" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Allergies" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="ChronicConditions" class="form-label"></label>
        <textarea asp-for="ChronicConditions" class="form-control" rows="3"></textarea>
        <span asp-validation-for="ChronicConditions" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="CurrentMedications" class="form-label"></label>
        <textarea asp-for="CurrentMedications" class="form-control" rows="3"></textarea>
        <span asp-validation-for="CurrentMedications" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
        <a asp-action="Details" asp-route-patientId="@Model.PatientId" class="btn btn-secondary">Anuluj</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
