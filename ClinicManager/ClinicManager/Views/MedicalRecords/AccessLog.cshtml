@using System.ComponentModel.DataAnnotations
@using System.Reflection
@model PagedResult<MedicalRecordAccessLogDto>
@{
    ViewData["Title"] = "Log dostepow do kartoteki";
    var patientId = (int)ViewData["PatientId"]!;

    string DisplayEnum(Enum value)
    {
        var name = value.ToString();
        var member = value.GetType().GetMember(name).FirstOrDefault();
        return member?.GetCustomAttribute<DisplayAttribute>()?.Name ?? name;
    }

    var rangeStart = Model.TotalCount == 0 ? 0 : (Model.Page - 1) * Model.PageSize + 1;
    var rangeEnd = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Log dostepow do kartoteki (RODO)</h2>
    <a asp-action="Details" asp-route-patientId="@patientId" class="btn btn-outline-secondary">Powrot</a>
</div>

<p class="text-muted">
    @if (Model.TotalCount == 0)
    {
        <span>Brak wpisow w logu.</span>
    }
    else
    {
        <span>Pokazano @rangeStart - @rangeEnd z @Model.TotalCount wpisow (strona @Model.Page z @Model.TotalPages).</span>
    }
</p>

@if (Model.Items.Any())
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Data dostepu (UTC)</th>
                <th>Uzytkownik</th>
                <th>Akcja</th>
                <th>Adres IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.Items)
            {
                <tr>
                    <td>@log.AccessedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@log.UserName</td>
                    <td>@DisplayEnum(log.Action)</td>
                    <td><code>@(log.IpAddress ?? "-")</code></td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginacja logow">
            <ul class="pagination">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="AccessLog"
                       asp-route-patientId="@patientId"
                       asp-route-page="@(Model.Page - 1)">Poprzednia</a>
                </li>

                @{
                    var startPage = Math.Max(1, Model.Page - 2);
                    var endPage = Math.Min(Model.TotalPages, Model.Page + 2);
                }

                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="AccessLog" asp-route-patientId="@patientId" asp-route-page="1">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                @for (var i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="AccessLog" asp-route-patientId="@patientId" asp-route-page="@i">@i</a>
                    </li>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="AccessLog"
                           asp-route-patientId="@patientId"
                           asp-route-page="@Model.TotalPages">@Model.TotalPages</a>
                    </li>
                }

                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="AccessLog"
                       asp-route-patientId="@patientId"
                       asp-route-page="@(Model.Page + 1)">Nastepna</a>
                </li>
            </ul>
        </nav>
    }
}
