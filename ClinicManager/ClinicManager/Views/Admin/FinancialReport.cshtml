@model ClinicManager.Models.ViewModels.FinancialReportViewModel
@{
    ViewData["Title"] = "Raporty finansowe";
    
    // Convert DateOnly to format for HTML input "yyyy-MM-dd"
    string DateFromValue = Model.DateFrom?.ToString("yyyy-MM-dd") ?? "";
    string DateToValue = Model.DateTo?.ToString("yyyy-MM-dd") ?? "";
}

<!-- Glassmorphism dashboard panel -->
<div class="container-fluid py-4" style="background: radial-gradient(circle at 10% 20%, rgba(243, 244, 246, 0.5) 0%, rgba(248, 250, 252, 0.5) 90%); border-radius: 16px;">
    
    <!-- Title and Export buttons header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1" style="background: linear-gradient(135deg, #1e1b4b 0%, #4f46e5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Raporty finansowe świadczeń
            </h2>
            <p class="text-muted mb-0">Agregacja kosztów procedur i leków, filtrowanie i generowanie raportów PDF.</p>
        </div>
        <div>
            <!-- PDF Export trigger -->
            <a asp-action="FinancialReportPdf" 
               asp-route-patientId="@Model.PatientId" 
               asp-route-doctorId="@Model.DoctorId" 
               asp-route-dateFrom="@DateFromValue" 
               asp-route-dateTo="@DateToValue" 
               class="btn btn-lg text-white shadow-sm fw-semibold"
               style="background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%); border: none; border-radius: 8px;">
                <i class="bi bi-file-earmark-pdf-fill me-2"></i> Eksportuj do PDF
            </a>
        </div>
    </div>

    <!-- Interactive Search / Filter Panel with subtle styling -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px);">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3" style="color: #1e1b4b;">Filtrowanie raportu</h5>
            <form asp-action="FinancialReport" method="get" class="row g-3">
                
                <!-- Patient Selector -->
                <div class="col-md-3">
                    <label for="patientId" class="form-label fw-semibold text-muted">Pacjent</label>
                    <select id="patientId" name="patientId" class="form-select border-grey" style="border-radius: 6px;">
                        <option value="">— Wszyscy pacjenci —</option>
                        @foreach (var p in Model.Patients)
                        {
                            <!option value="@p.Id" @(Model.PatientId == p.Id ? "selected" : "")>
                                @p.LastName @p.FirstName (@p.Pesel)
                            </!option>
                        }
                    </select>
                </div>

                <!-- Doctor Selector -->
                <div class="col-md-3">
                    <label for="doctorId" class="form-label fw-semibold text-muted">Lekarz prowadzący</label>
                    <select id="doctorId" name="doctorId" class="form-select border-grey" style="border-radius: 6px;">
                        <option value="">— Wszyscy lekarze —</option>
                        @foreach (var d in Model.Doctors)
                        {
                            <!option value="@d.Id" @(Model.DoctorId == d.Id ? "selected" : "")>
                                @d.LastName @d.FirstName
                            </!option>
                        }
                    </select>
                </div>

                <!-- Date From -->
                <div class="col-md-2">
                    <label for="dateFrom" class="form-label fw-semibold text-muted">Data od</label>
                    <input type="date" id="dateFrom" name="dateFrom" value="@DateFromValue" class="form-control border-grey" style="border-radius: 6px;" />
                </div>

                <!-- Date To -->
                <div class="col-md-2">
                    <label for="dateTo" class="form-label fw-semibold text-muted">Data do</label>
                    <input type="date" id="dateTo" name="dateTo" value="@DateToValue" class="form-control border-grey" style="border-radius: 6px;" />
                </div>

                <!-- Submit buttons -->
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold" style="background-color: #4f46e5; border: none; height: 38px; border-radius: 6px;">
                        Filtruj
                    </button>
                    <a asp-action="FinancialReport" class="btn btn-outline-secondary w-100 fw-semibold" style="height: 38px; border-radius: 6px;">
                        Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Financial Summary Cards -->
    <div class="row g-3 mb-4">
        
        <!-- Total Cost Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-white" style="border-radius: 12px; background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <span class="text-white-50 fw-semibold uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em;">Łączny koszt świadczeń</span>
                        <h2 class="fw-bold mt-2 mb-0" style="font-size: 2.2rem;">@Model.TotalCost.ToString("N2") <span style="font-size: 1.2rem;">PLN</span></h2>
                    </div>
                    <div class="mt-3">
                        <i class="bi bi-wallet2" style="font-size: 1.5rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Procedures Cost Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-white" style="border-radius: 12px; background: linear-gradient(135deg, #065f46 0%, #047857 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <span class="text-white-50 fw-semibold uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em;">Koszt wykonanych procedur</span>
                        <h2 class="fw-bold mt-2 mb-0" style="font-size: 2.2rem;">@Model.TotalProceduresCost.ToString("N2") <span style="font-size: 1.2rem;">PLN</span></h2>
                    </div>
                    <div class="mt-3">
                        <i class="bi bi-heart-pulse" style="font-size: 1.5rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Medications Cost Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-white" style="border-radius: 12px; background: linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <span class="text-white-50 fw-semibold uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em;">Koszt przepisanych leków</span>
                        <h2 class="fw-bold mt-2 mb-0" style="font-size: 2.2rem;">@Model.TotalMedicationsCost.ToString("N2") <span style="font-size: 1.2rem;">PLN</span></h2>
                    </div>
                    <div class="mt-3">
                        <i class="bi bi-capsule" style="font-size: 1.5rem; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs Navigation for different aggregations -->
    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden; background-color: white;">
        <div class="card-header bg-white border-0 pt-3 px-4">
            <ul class="nav nav-pills card-header-pills mb-2 gap-2" id="financialReportTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-semibold" id="patient-tab" data-bs-toggle="tab" data-bs-target="#patient-pane" type="button" role="tab" aria-controls="patient-pane" aria-selected="true" style="border-radius: 8px;">
                        <i class="bi bi-person-lines-fill me-1"></i> Per pacjent
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-semibold" id="doctor-tab" data-bs-toggle="tab" data-bs-target="#doctor-pane" type="button" role="tab" aria-controls="doctor-pane" aria-selected="false" style="border-radius: 8px;">
                        <i class="bi bi-heart-pulse-fill me-1"></i> Per lekarz
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-semibold" id="month-tab" data-bs-toggle="tab" data-bs-target="#month-pane" type="button" role="tab" aria-controls="month-pane" aria-selected="false" style="border-radius: 8px;">
                        <i class="bi bi-calendar-event me-1"></i> Per miesiąc
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-semibold" id="detailed-tab" data-bs-toggle="tab" data-bs-target="#detailed-pane" type="button" role="tab" aria-controls="detailed-pane" aria-selected="false" style="border-radius: 8px;">
                        <i class="bi bi-list-columns-reverse me-1"></i> Wszystkie wizyty
                    </button>
                </li>
            </ul>
        </div>
        
        <div class="card-body p-4 tab-content" id="financialReportTabContent">
            
            <!-- 1. PATIENT aggregation pane -->
            <div class="tab-pane fade show active" id="patient-pane" role="tabpanel" aria-labelledby="patient-tab">
                <h5 class="fw-bold mb-3" style="color: #1e1b4b;">Koszty świadczeń pogrupowane per Pacjent</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Pacjent</th>
                                <th class="text-end">Suma za procedury</th>
                                <th class="text-end">Suma za leki</th>
                                <th class="text-end fw-bold text-indigo">Suma łączna</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.GroupedByPatient.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Brak danych dla wybranych filtrów.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var g in Model.GroupedByPatient)
                                {
                                    <tr>
                                        <td><strong>@g.GroupKey</strong></td>
                                        <td class="text-end text-success fw-medium">@g.ProceduresCost.ToString("N2") zł</td>
                                        <td class="text-end text-primary fw-medium">@g.MedicationsCost.ToString("N2") zł</td>
                                        <td class="text-end fw-bold" style="color: #1e1b4b;">@g.TotalCost.ToString("N2") zł</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 2. DOCTOR aggregation pane -->
            <div class="tab-pane fade" id="doctor-pane" role="tabpanel" aria-labelledby="doctor-tab">
                <h5 class="fw-bold mb-3" style="color: #1e1b4b;">Koszty świadczeń pogrupowane per Lekarz</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Lekarz</th>
                                <th class="text-end">Suma za procedury</th>
                                <th class="text-end">Suma za leki</th>
                                <th class="text-end fw-bold text-indigo">Suma łączna</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.GroupedByDoctor.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Brak danych dla wybranych filtrów.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var g in Model.GroupedByDoctor)
                                {
                                    <tr>
                                        <td><strong>@g.GroupKey</strong></td>
                                        <td class="text-end text-success fw-medium">@g.ProceduresCost.ToString("N2") zł</td>
                                        <td class="text-end text-primary fw-medium">@g.MedicationsCost.ToString("N2") zł</td>
                                        <td class="text-end fw-bold" style="color: #1e1b4b;">@g.TotalCost.ToString("N2") zł</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 3. MONTH aggregation pane -->
            <div class="tab-pane fade" id="month-pane" role="tabpanel" aria-labelledby="month-tab">
                <h5 class="fw-bold mb-3" style="color: #1e1b4b;">Koszty świadczeń pogrupowane per Miesiąc</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Miesiąc</th>
                                <th class="text-end">Suma za procedury</th>
                                <th class="text-end">Suma za leki</th>
                                <th class="text-end fw-bold text-indigo">Suma łączna</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.GroupedByMonth.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Brak danych dla wybranych filtrów.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var g in Model.GroupedByMonth)
                                {
                                    <tr>
                                        <td><strong>@g.GroupKey</strong></td>
                                        <td class="text-end text-success fw-medium">@g.ProceduresCost.ToString("N2") zł</td>
                                        <td class="text-end text-primary fw-medium">@g.MedicationsCost.ToString("N2") zł</td>
                                        <td class="text-end fw-bold" style="color: #1e1b4b;">@g.TotalCost.ToString("N2") zł</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 4. DETAILED visits list pane -->
            <div class="tab-pane fade" id="detailed-pane" role="tabpanel" aria-labelledby="detailed-tab">
                <h5 class="fw-bold mb-3" style="color: #1e1b4b;">Szczegóły pojedynczych wizyt</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Data wizyty</th>
                                <th>Pacjent</th>
                                <th>Lekarz</th>
                                <th>Procedury i leki (Szczegóły)</th>
                                <th class="text-end">Procedury (PLN)</th>
                                <th class="text-end">Leki (PLN)</th>
                                <th class="text-end fw-bold text-indigo">Suma (PLN)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Items.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">Brak danych dla wybranych filtrów.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="text-nowrap">@item.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            <strong>@item.PatientName</strong>
                                            <small class="text-muted d-block">PESEL: @item.PatientPesel</small>
                                        </td>
                                        <td>@item.DoctorName</td>
                                        <td>
                                            <!-- Mini list of procedures & medications -->
                                            @if (item.Procedures.Any())
                                            {
                                                <div class="mb-1">
                                                    <span class="text-xs fw-bold text-success d-block" style="font-size: 0.75rem;">Procedury:</span>
                                                    @foreach (var proc in item.Procedures)
                                                    {
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle me-1 mb-1" style="font-size: 0.75rem;">@proc</span>
                                                    }
                                                </div>
                                            }
                                            @if (item.Medications.Any())
                                            {
                                                <div>
                                                    <span class="text-xs fw-bold text-primary d-block" style="font-size: 0.75rem;">Leki:</span>
                                                    @foreach (var med in item.Medications)
                                                    {
                                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle me-1 mb-1" style="font-size: 0.75rem;">@med</span>
                                                    }
                                                </div>
                                            }
                                            @if (!item.Procedures.Any() && !item.Medications.Any())
                                            {
                                                <span class="text-muted italic" style="font-size: 0.8rem;">Brak procedur/leków</span>
                                            }
                                        </td>
                                        <td class="text-end fw-medium text-success">@item.ProceduresCost.ToString("N2") zł</td>
                                        <td class="text-end fw-medium text-primary">@item.MedicationsCost.ToString("N2") zł</td>
                                        <td class="text-end fw-bold" style="color: #1e1b4b;">@item.TotalCost.ToString("N2") zł</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <!-- Custom styling to override Bootstrap nav-pill active color and style the dashboard -->
    <style>
        .nav-pills .nav-link.active {
            background-color: #4f46e5 !important;
            color: white !important;
        }
        .nav-pills .nav-link {
            color: #4b5563;
        }
        .nav-pills .nav-link:hover:not(.active) {
            background-color: #f3f4f6;
            color: #1f2937;
        }
        .border-grey {
            border-color: #cbd5e1 !important;
        }
        .bg-success-subtle {
            background-color: #d1fae5 !important;
        }
        .text-success {
            color: #065f46 !important;
        }
        .border-success-subtle {
            border-color: #a7f3d0 !important;
        }
        .bg-primary-subtle {
            background-color: #dbeafe !important;
        }
        .text-primary {
            color: #1e40af !important;
        }
        .border-primary-subtle {
            border-color: #bfdbfe !important;
        }
    </style>
}
