@model ProcedurePerformedFormDto
@{
    ViewData["Title"] = "Dodaj procedurę";
    var visitId = (int)ViewBag.VisitId;
}

<h2>Dodaj procedurę medyczną</h2>

<form asp-action="AddProcedure" asp-route-visitId="@visitId" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="col-md-8">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="np. RTG klatki piersiowej" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Cost" class="form-label"></label>
        <div class="input-group">
            <input asp-for="Cost" class="form-control" type="number" step="0.01" min="0" />
            <span class="input-group-text">PLN</span>
        </div>
        <span asp-validation-for="Cost" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Zapisz</button>
        <a asp-controller="Visits" asp-action="Details" asp-route-id="@visitId" class="btn btn-secondary">Anuluj</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
