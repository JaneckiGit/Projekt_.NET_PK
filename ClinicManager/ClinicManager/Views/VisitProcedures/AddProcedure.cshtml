@model ProcedurePerformedFormDto
@{
    ViewData["Title"] = "Dodaj procedurę";
    var visitId = (int)ViewBag.VisitId;
    var catalogProcedures = ViewBag.CatalogProcedures as IReadOnlyList<ProcedureOptionDto> ?? new List<ProcedureOptionDto>();
}

<h2>Dodaj procedurę medyczną</h2>

<form asp-action="AddProcedure" asp-route-visitId="@visitId" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="col-md-12">
        <label asp-for="ProcedureId" class="form-label"></label>
        <select asp-for="ProcedureId" class="form-select" id="CatalogProcedureSelect">
            <option value="">— wybierz procedurę z katalogu (opcjonalnie) —</option>
            @foreach (var proc in catalogProcedures)
            {
                <option value="@proc.Id" 
                        data-name="@proc.Name" 
                        data-cost="@proc.Cost.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" 
                        data-description="@proc.Description">
                    @proc.DisplayName
                </option>
            }
        </select>
        <span asp-validation-for="ProcedureId" class="text-danger"></span>
        <div class="form-text text-muted">Wybranie procedury z katalogu automatycznie uzupełni poniższe pola.</div>
    </div>

    <div class="col-md-8">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" id="ProcedureName" placeholder="np. RTG klatki piersiowej" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Cost" class="form-label"></label>
        <div class="input-group">
            <input asp-for="Cost" class="form-control" type="number" step="0.01" min="0" id="ProcedureCost" />
            <span class="input-group-text">PLN</span>
        </div>
        <span asp-validation-for="Cost" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3" id="ProcedureDescription"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Zapisz</button>
        <a asp-controller="Visits" asp-action="Details" asp-route-id="@visitId" class="btn btn-secondary">Anuluj</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            $('#CatalogProcedureSelect').change(function() {
                var selectedOption = $(this).find('option:selected');
                var id = $(this).val();

                if (id) {
                    var name = selectedOption.data('name') || '';
                    var cost = selectedOption.data('cost') || '0.00';
                    var desc = selectedOption.data('description') || '';

                    $('#ProcedureName').val(name);
                    $('#ProcedureCost').val(cost);
                    $('#ProcedureDescription').val(desc);
                }
            });
        });
    </script>
}
