@using Microsoft.AspNetCore.Mvc.Rendering
@model PrescribedMedicationFormDto
@{
    ViewData["Title"] = "Edytuj lek";
    var visitId = (int)ViewBag.VisitId;
    var medications = ViewBag.Medications as SelectList;
}

<h2>Edytuj przepisany lek</h2>

<form asp-action="EditMedication" asp-route-id="@Model.Id" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="visitId" value="@visitId" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="col-md-12">
        <label asp-for="MedicationId" class="form-label"></label>
        <select asp-for="MedicationId" class="form-select" asp-items="medications">
            <option value="">— wybierz lek z katalogu —</option>
        </select>
        <span asp-validation-for="MedicationId" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Dosage" class="form-label"></label>
        <input asp-for="Dosage" class="form-control" />
        <span asp-validation-for="Dosage" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Quantity" class="form-label"></label>
        <input asp-for="Quantity" class="form-control" type="number" min="1" max="9999" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Cost" class="form-label"></label>
        <div class="input-group">
            <input asp-for="Cost" class="form-control" type="number" step="0.01" min="0" />
            <span class="input-group-text">PLN</span>
        </div>
        <span asp-validation-for="Cost" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
        <a asp-controller="Visits" asp-action="Details" asp-route-id="@visitId" class="btn btn-secondary">Anuluj</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
