@using System.ComponentModel.DataAnnotations
@using System.Reflection
@using Microsoft.AspNetCore.Mvc.Rendering
@model IReadOnlyList<VisitDto>
@{
    ViewData["Title"] = "Wizyty";
    var filter = ViewData["Filter"] as VisitListFilterDto ?? new VisitListFilterDto();
    var doctors = ViewBag.Doctors as SelectList;

    var canManage = User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Rejestratorka);

    string DisplayEnum(Enum value)
    {
        var name = value.ToString();
        var member = value.GetType().GetMember(name).FirstOrDefault();
        return member?.GetCustomAttribute<DisplayAttribute>()?.Name ?? name;
    }

    string StatusBadge(VisitStatus status) => status switch
    {
        VisitStatus.Planned => "bg-primary",
        VisitStatus.InProgress => "bg-warning text-dark",
        VisitStatus.Completed => "bg-success",
        VisitStatus.Cancelled => "bg-secondary",
        _ => "bg-light text-dark"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Wizyty</h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Zaplanuj wizytę</a>
    }
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-3">
        <label class="form-label" for="DateFrom">Data od</label>
        <input type="date" id="DateFrom" name="DateFrom"
               value="@(filter.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="DateTo">Data do</label>
        <input type="date" id="DateTo" name="DateTo"
               value="@(filter.DateTo?.ToString("yyyy-MM-dd"))" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label" for="Status">Status</label>
        <select id="Status" name="Status" class="form-select">
            <option value="">— dowolny —</option>
            @foreach (VisitStatus s in Enum.GetValues<VisitStatus>())
            {
                if (filter.Status == s)
                {
                    <option value="@((int)s)" selected>@DisplayEnum(s)</option>
                }
                else
                {
                    <option value="@((int)s)">@DisplayEnum(s)</option>
                }
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label" for="DoctorId">Lekarz</label>
        <select id="DoctorId" name="DoctorId" class="form-select">
            <option value="">— dowolny —</option>
            @if (doctors is not null)
            {
                foreach (var d in doctors)
                {
                    if (d.Value == filter.DoctorId)
                    {
                        <option value="@d.Value" selected>@d.Text</option>
                    }
                    else
                    {
                        <option value="@d.Value">@d.Text</option>
                    }
                }
            }
        </select>
    </div>
    <div class="col-md-1 d-flex gap-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filtruj</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">Brak wizyt spełniających kryteria.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Termin</th>
                <th>Pacjent</th>
                <th>PESEL</th>
                <th>Lekarz</th>
                <th>Status</th>
                <th class="text-end">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@v.PatientDisplayName</td>
                    <td>@v.PatientPesel</td>
                    <td>@v.DoctorDisplayName</td>
                    <td><span class="badge @StatusBadge(v.Status)">@DisplayEnum(v.Status)</span></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-secondary">Szczegóły</a>
                        @if (canManage)
                        {
                            <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                            @if (v.Status != VisitStatus.Cancelled && v.Status != VisitStatus.Completed)
                            {
                                <a asp-action="Cancel" asp-route-id="@v.Id" class="btn btn-sm btn-outline-danger">Anuluj</a>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
