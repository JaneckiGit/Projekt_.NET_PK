@using Microsoft.AspNetCore.Mvc.Rendering
@model VisitFormDto
@{
    ViewData["Title"] = "Zaplanuj wizytę";
    var doctors = ViewBag.Doctors as SelectList;
    var patients = ViewBag.Patients as SelectList;
}

<h2>Zaplanuj wizytę</h2>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="col-md-6">
        <label asp-for="ScheduledAt" class="form-label"></label>
        <input asp-for="ScheduledAt" class="form-control" type="datetime-local" />
        <span asp-validation-for="ScheduledAt" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="DoctorId" class="form-label"></label>
        <select asp-for="DoctorId" class="form-select" asp-items="doctors">
            <option value="">— wybierz lekarza —</option>
        </select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="PatientId" class="form-label"></label>
        <select asp-for="PatientId" class="form-select" asp-items="patients">
            <option value="">— wybierz pacjenta —</option>
        </select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Zapisz</button>
        <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
