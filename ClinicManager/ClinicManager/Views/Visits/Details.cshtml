@using System.ComponentModel.DataAnnotations
@using System.Reflection
@model VisitDto
@{
    ViewData["Title"] = $"Wizyta: {Model.PatientDisplayName}";
    var canManage = User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Rejestratorka);

    string DisplayEnum(Enum value)
    {
        var name = value.ToString();
        var member = value.GetType().GetMember(name).FirstOrDefault();
        return member?.GetCustomAttribute<DisplayAttribute>()?.Name ?? name;
    }

    string StatusBadge(VisitStatus status) => status switch
    {
        VisitStatus.Planned => "bg-primary",
        VisitStatus.InProgress => "bg-warning text-dark",
        VisitStatus.Completed => "bg-success",
        VisitStatus.Cancelled => "bg-secondary",
        _ => "bg-light text-dark"
    };
}

<h2>Szczegóły wizyty</h2>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<dl class="row">
    <dt class="col-sm-3">Termin</dt>
    <dd class="col-sm-9">@Model.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9"><span class="badge @StatusBadge(Model.Status)">@DisplayEnum(Model.Status)</span></dd>

    <dt class="col-sm-3">Pacjent</dt>
    <dd class="col-sm-9">@Model.PatientDisplayName (PESEL: @Model.PatientPesel)</dd>

    <dt class="col-sm-3">Lekarz</dt>
    <dd class="col-sm-9">@Model.DoctorDisplayName</dd>

    <dt class="col-sm-3">Notatki</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</dd>

    <dt class="col-sm-3">Utworzono</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>

    @if (Model.UpdatedAt.HasValue)
    {
        <dt class="col-sm-3">Ostatnia aktualizacja</dt>
        <dd class="col-sm-9">@Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
    }
</dl>

<div class="d-flex gap-2 mb-4">
    @if (canManage)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edytuj</a>
        @if (Model.Status != VisitStatus.Cancelled && Model.Status != VisitStatus.Completed)
        {
            <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-outline-danger">Anuluj wizytę</a>
        }
    }
    <a asp-action="Index" class="btn btn-secondary">Powrót do listy</a>
</div>
