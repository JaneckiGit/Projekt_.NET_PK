@model IReadOnlyList<PatientDto>
@{
    ViewData["Title"] = "Pacjenci";
    var query = ViewData["Query"] as string;
}

@{
    var canManage = User.IsInRole("Rejestratorka") || User.IsInRole("Admin");
    var canViewRecord = User.IsInRole("Lekarz") || User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Pacjenci</h2>
    @if (canManage)
    {
        <a asp-action="Create" class="btn btn-primary">Dodaj pacjenta</a>
    }
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="q" value="@query" class="form-control"
               placeholder="Szukaj po imieniu, nazwisku lub PESEL..." />
        <button type="submit" class="btn btn-outline-secondary">Szukaj</button>
        @if (!string.IsNullOrWhiteSpace(query))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Wyczyść</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">Brak pacjentów spełniających kryteria.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Nazwisko</th>
                <th>Imię</th>
                <th>PESEL</th>
                <th>Nr ubezpieczenia</th>
                <th>Telefon</th>
                <th class="text-end">Akcje</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.LastName</td>
                <td>@p.FirstName</td>
                <td>@p.Pesel</td>
                <td>@p.InsuranceNumber</td>
                <td>@p.PhoneNumber</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Szczegóły</a>
                    @if (canViewRecord)
                    {
                        <a asp-controller="MedicalRecords" asp-action="Details" asp-route-patientId="@p.Id"
                           class="btn btn-sm btn-outline-success">Kartoteka</a>
                    }
                    @if (canManage)
                    {
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
